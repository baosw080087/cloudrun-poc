#3. 创建对应的 NEG (网络端点组)
#LB 需要通过 NEG 才能找到这两个独立的服务：


# 为蓝色服务创建 NEG
gcloud compute network-endpoint-groups create neg-blue \
    --region=asia-northeast1 \
    --network-endpoint-type=SERVERLESS \
    --cloud-run-service=my-go-app-blue

# 为绿色服务创建 NEG
gcloud compute network-endpoint-groups create neg-green \
    --region=asia-northeast1 \
    --network-endpoint-type=SERVERLESS \
    --cloud-run-service=my-go-app-green

# 4. 关联到后端服务 (Backend Services)
# 确保你已经按照上一步的操作，使用了 EXTERNAL_MANAGED 模式创建了后端，现在把 NEG 挂载上去：

# 关联蓝色后端
gcloud compute backend-services add-backend backend-blue \
    --global \
    --network-endpoint-group=neg-blue \
    --network-endpoint-group-region=asia-northeast1

# 关联绿色后端
gcloud compute backend-services add-backend backend-green \
    --global \
    --network-endpoint-group=neg-green \
    --network-endpoint-group-region=asia-northeast1

