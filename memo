    # 设置变量
export PROJECT_ID="project-95db9422-29d0-4c5e-b9f"
export POOL_NAME="github-pool"
export PROVIDER_NAME="github-provider"
export REPO_NAME="baosw080087/cloudrun-poc" # 例如: baosw/cloudrun-poc

# 创建身份池
gcloud iam workload-identity-pools create $POOL_NAME \
    --project="${PROJECT_ID}" \
    --location="global" \
    --display-name="GitHub Actions Pool"

# 创建身份提供者 (允许 GitHub 访问)
gcloud iam workload-identity-pools providers create-oidc $PROVIDER_NAME \
    --project="${PROJECT_ID}" \
    --location="global" \
    --workload-identity-pool=$POOL_NAME \
    --display-name="GitHub Provider" \
    --attribute-mapping="google.subject=assertion.sub,attribute.actor=assertion.actor,attribute.repository=assertion.repository" \
    --issuer-uri="https://token.actions.githubusercontent.com" \
    --attribute-condition="attribute.repository == '$REPO_NAME'"

# 绑定服务账号给 GitHub 仓库
gcloud iam service-accounts add-iam-policy-binding "github-actions-deployer@${PROJECT_ID}.iam.gserviceaccount.com" \
    --project="${PROJECT_ID}" \
    --role="roles/iam.workloadIdentityUser" \
    --member="principalSet://iam.googleapis.com/projects/$(gcloud projects describe $PROJECT_ID --format='value(projectNumber)')/locations/global/workloadIdentityPools/$POOL_NAME/attribute.repository/$REPO_NAME"